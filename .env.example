# Copy to .env for local dev, or set these in your host's dashboard (e.g. Render).
# All are OPTIONAL — the app runs fully without them (rule-based narration fallback).
# Server-side only; never exposed to the browser.

# Preferred provider for NPC narration + end-of-week summary (OpenAI-compatible).
OPENROUTER_API_KEY=
# Optional model override (default: anthropic/claude-3.5-haiku).
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Fallback provider, used only if OPENROUTER_API_KEY is absent.
# ANTHROPIC_API_KEY=
